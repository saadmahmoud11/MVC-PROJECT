@model IEnumerable<EmployeeDto>
@{
    ViewData["Title"] = "Index";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<div class="card border border-primary ">
    <div class="card-header bg-primary">
        <h1 class="text-white">All Employees</h1>
    </div>
    <div class="card-body ">
        <a asp-action="Create" class="btn btn-success">Create Employee</a>
        @if (Model.Any())
        {
            <div class="m-2">
                <form method="get" asp-action="Index" class="row offset-2">
                    <div class="col-8">
                        <input type="text" name="searchValue" class="form-control me-2" placeholder="Search by name or email" value="@Context.Request.Query["searchValue"]" />
                    </div>
                    <div class="col-4">
                        <button type="submit" class="btn btn-dark" value="search">Search</button>
                    </div>
                </form>
            </div>
            <table class="table table-striped table-hover mt-3">
                <thead class="text-center">
                    <tr>
                        <th>@Html.DisplayNameFor(e => e.Name)</th>
                        <th>@Html.DisplayNameFor(e => e.ImageName)</th>
                        <th>@Html.DisplayNameFor(e => e.Email)</th>
                        <th>@Html.DisplayNameFor(e => e.EmployeeType)</th>
                        <th>Department</th>
                        <th>@Html.DisplayNameFor(e => e.Age)</th>
                        <th>@Html.DisplayNameFor(e => e.Salary)</th>
                        <th>@Html.DisplayNameFor(e => e.IsActive)</th>
                        <th>@Html.DisplayNameFor(e => e.Gender)</th>
                        <th>Details </th>
                        <th>Update</th>
                        <th>Delete</th>
                    </tr>
                </thead>
                <tbody class="text-center">
                    @foreach (var employee in Model)
                    {
                        <tr>

                            <td>@employee.Name</td>
                            <td><img src="~/files/images/@employee.ImageName" class="img-fluid rounded-3 w-50 h-25"/></td>
                            <td>@employee.Email</td>
                            <td>@employee.EmployeeType</td>
                            <td>@employee.DepartmentName</td>
                            <td>@employee.Age</td>
                            <td>@employee.Salary</td>
                            <td>@employee.IsActive</td>
                            <td>@employee.Gender</td>
                            <partial name="_ButtonsPartialViews" model="@employee.Id" />

                            @* <td>
                                <a class="btn btn-primary" asp-action="Details" asp-route-id="@employee.Id">
                                    <i class="fas fa-eye"></i> Details
                                </a>
                            </td>
                            <td>
                                <a class="btn btn-warning" asp-action="Edit" asp-route-id="@employee.Id">
                                    <i class="fas fa-edit"></i> Edit
                                </a>
                            </td>
                            <td> *@
                            @* <a class="btn btn-danger" asp-action="Delete" asp-route-id="@employee.Id">
                                    <i class="fas fa-trash"></i> Delete
                                </a> *@
                            @*     <button type="button" class="btn btn-danger" asp-action="Delete" asp-route-empId="@employee.Id" data-bs-toggle="modal" data-bs-target="#deleteModal-@employee.Id">
                                    <i class="fas fa-trash"></i> Delete
                                </button>
                                <!-- Delete Modal -->
                            </td> *@
                            <div class="modal fade" id="deleteModal-@employee.Id" tabindex="-1" aria-labelledby="exampleModalLabel" aria-hidden="true">
                                <div class="modal-dialog">
                                    <div class="modal-content">
                                        <div class="modal-header">
                                            <h1 class="modal-title fs-5" id="exampleModalLabel">Delete Employee</h1>
                                            <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
                                        </div>
                                        <div class="modal-body">
                                            Are You Sure to Delete @employee.Name ?
                                        </div>
                                        <div class="modal-footer">
                                            <form method="post" asp-action="Delete" asp-route-empId="@employee.Id" class="mt-4">
                                                <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Close</button>
                                                <input type="submit" value="Delete" class="btn btn-danger" />
                                            </form>
                                        </div>
                                    </div>
                                </div>
                            </div>

                        </tr>
                    }
                </tbody>
            </table>
        }
        else
        {
            <div class="alert alert-info mt-2 ">
                <h2>No Employees Found</h2>
            </div>
        }
    </div>
</div>




