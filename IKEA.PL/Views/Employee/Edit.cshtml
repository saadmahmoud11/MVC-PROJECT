                        <input class="form-check-input " type="radio" asp-for="EmpGender" value="@genderOption" />
                        <label class="form-check-label" for="Gender">@genderOption</label>
                    </div>
                }
                <span asp-validation-for="EmpGender" class="text-danger"></span>
            </div>
            <div class="form-group mb-3 col-6">
                <input asp-for="IsActive" class="form-check-input" />
                <label class="col-form-label" asp-for="IsActive"></label>
            </div> *@


            <div asp-validation-summary="ModelOnly"></div>
            <div class="mt-4 m-auto">
                <input class="btn btn-success" type="submit" value="Update Employee" />
