@model IEnumerable<DepartmentDto>
@{
    // string Message = @ViewData["Message"] as string;
    Layout = "~/Views/Shared/_Layout.cshtml";

}

<div class="card border border-primary">
    <div class="card-header bg-primary">
        <h1 class="my-3">All Departments</h1>
    </div>
    <div class="card-body">
        @if (@TempData["Message"] != null)
        {
            <div class="alert alert-success">
                @* <h2>@ViewData["Message"]</h2>
            <h2>@ViewBag.Message</h2> *@
                <h2>@TempData["Message"]</h2>
            </div>
        }

        <a asp-action="Create" class="btn btn-success">Create Department</a>
        @if (Model.Any())
        {
            <table class="table table-striped table-hover mt-2">
                <thead class="text-center">
                    <tr>
                        <th>@Html.DisplayNameFor(d => d.Code)</th>
                        <th>@Html.DisplayNameFor(d => d.Name)</th>
                        <th>@Html.DisplayNameFor(d => d.Description)</th>
                        <th>Details</th>
                        <th>Update</th>
                        <th>Delete</th>

                    </tr>
                </thead>
                <tbody class="text-center">
                    @foreach (var dept in Model)
                    {

                        <tr>
                            <td>@dept.Code</td>
                            <td>@dept.Name</td>
                            <td>@dept.Description</td>
                            <partial name="_ButtonsPartialViews" model="@dept.Id" />

                            @* <td><a asp-action="Details" asp-route-id="@dept.Id" class="btn btn-primary"><i class="fas fa-eye"></i> Details</a></td>
                            <td><a asp-action="Edit" asp-route-id="@dept.Id" class="btn btn-warning"><i class="fas fa-edit"></i> Update</a></td>
                            <td> *@
                                @* <a asp-action="Delete" asp-route-id="@dept.Id" class="btn btn-danger"><i class="fas fa-trash"></i> Delete</a> *@
                            @*     <button type="button" class="btn btn-danger" data-bs-toggle="modal" data-bs-target="#DeleteDepartment">
                                    <i class="fas fa-trash"></i> Delete
                                </button>
                            </td> *@

                        </tr>
                        <div class="modal fade" id="DeleteDepartment" tabindex="-1" aria-labelledby="exampleModalLabel" aria-hidden="true">
                            <div class="modal-dialog">
                                <div class="modal-content">
                                    <div class="modal-header">
                                        <h1 class="modal-title fs-5" id="exampleModalLabel">Delete Department</h1>
                                        <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
                                    </div>
                                    <div class="modal-body">
                                        <h4 class="modal-title fs-5" id="exampleModalLabel">
                                            Are you sure to Delete @dept.Name Department ?
                                        </h4>
                                        ...
                                    </div>
                                    <div class="modal-footer">
                                        <form asp-action="Delete" asp-route-deptId="@dept.Id" method="post">
                                            <div asp-validation-summary="ModelOnly" class="text-danger">
                                            </div>
                                            <div class="mt-4">
                                                <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Close</button>
                                                <input type="submit" value="Delete" class="btn btn-danger" />
                                            </div>
                                        </form>
                                    </div>
                                </div>
                            </div>
                        </div>
                    }
                </tbody>
            </table>
        }
        else
        {
            <div class="alert alert-info mt-2 ">
                <h2>No depts found</h2>
            </div>
        }
    </div>
</div>




